# Baruti Legacy Foundation — Configuration Apache
# Copié automatiquement dans dist/ lors du build Vite

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Ne pas réécrire index.html
  RewriteRule ^index\.html$ - [L]

  # Laisser passer fichiers et dossiers existants (assets, images, etc.)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Vue Router — history mode : toutes les routes → index.html
  RewriteRule . /index.html [L]
</IfModule>

# Compression GZIP
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# Cache navigateur
<IfModule mod_expires.c>
  ExpiresActive On

  # Assets Vite (hashés) — cache long
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"

  # Images et icônes
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"

  # HTML — pas de cache agressif
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# UTF-8
AddDefaultCharset UTF-8

# Sécurité de base
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
